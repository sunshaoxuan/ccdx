<%- include('../partials/header') %>

<section class="py-20 max-w-4xl mx-auto px-6">
    <div class="text-center mb-12">
        <h2 class="text-3xl serif tracking-widest mb-4"><%= __('order.history') %></h2>
        <div class="w-12 h-[1px] bg-[#D4B483] mx-auto"></div>
    </div>

    <% if (orders.length === 0) { %>
        <div class="text-center py-20">
            <p class="text-gray-400 text-sm tracking-widest"><%= lang === 'zh' ? '暂无订单记录' : '注文履歴はありません' %></p>
        </div>
    <% } else { %>
        <div class="space-y-12">
            <% orders.forEach(order => { %>
                <div class="border border-gray-50 p-8">
                    <div class="flex flex-col md:flex-row justify-between mb-8 border-b border-gray-50 pb-6">
                        <div class="mb-4 md:mb-0">
                            <p class="text-[10px] tracking-widest text-gray-400 uppercase mb-1"><%= __('order.id') %></p>
                            <p class="text-sm font-light"><%= order._id %></p>
                        </div>
                        <div class="mb-4 md:mb-0">
                            <p class="text-[10px] tracking-widest text-gray-400 uppercase mb-1"><%= __('order.date') %></p>
                            <p class="text-sm font-light"><%= order.createdAt.toLocaleDateString() %></p>
                        </div>
                        <div>
                            <p class="text-[10px] tracking-widest text-gray-400 uppercase mb-1"><%= __('order.status') %></p>
                            <p class="text-sm font-light text-[#D4B483]"><%= __('order.' + order.status) %></p>
                        </div>
                    </div>
                    
                    <div class="space-y-4 mb-8">
                        <% order.items.forEach(item => { %>
                            <div class="flex justify-between items-center text-sm">
                                <span class="font-light"><%= item.name[lang] || item.name %> x <%= item.quantity %></span>
                                <span class="text-gray-400">￥<%= item.price * item.quantity %></span>
                            </div>
                        <% }) %>
                    </div>
                    
                    <div class="flex justify-between items-center pt-6 border-t border-gray-50">
                        <span class="text-xs tracking-widest text-gray-400 uppercase"><%= __('cart.total') %></span>
                        <span class="text-xl serif">￥<%= order.totalAmount %></span>
                    </div>
                </div>
            <% }) %>
        </div>
    <% } %>
</section>

<%- include('../partials/footer') %>
