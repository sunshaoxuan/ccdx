<%- include('../partials/header') %>

<section class="py-20 max-w-4xl mx-auto px-6">
    <div class="text-center mb-16">
        <h2 class="text-3xl serif tracking-widest mb-4"><%= __('nav.info') %></h2>
        <div class="w-12 h-[1px] bg-[#D4B483] mx-auto"></div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-16">
        <div class="space-y-12">
            <div>
                <p class="text-[10px] tracking-widest text-gray-400 uppercase mb-4">ADDRESS</p>
                <p class="text-sm font-light leading-loose">
                    东京都品川区南大井 2-11-4 3A 102<br>
                    2-11-4 Minamioi, Shinagawa-ku, Tokyo
                </p>
            </div>
            <div>
                <p class="text-[10px] tracking-widest text-gray-400 uppercase mb-4">CONTACT</p>
                <p class="text-sm font-light">03-4500-0510</p>
            </div>
            <div>
                <p class="text-[10px] tracking-widest text-gray-400 uppercase mb-4">HOURS</p>
                <p class="text-sm font-light leading-loose">
                    <% if (lang === 'zh') { %>
                        11:00 - 20:00<br>
                        定休日：每周四
                    <% } else { %>
                        11:00 - 20:00<br>
                        定休日：木曜日
                    <% } %>
                </p>
            </div>
        </div>
        <div class="aspect-square bg-gray-50 flex items-center justify-center overflow-hidden rounded-sm shadow-sm">
            <iframe 
                src="https://www.google.com/maps?q=CC点心,東京都品川区南大井2-11-4&output=embed" 
                width="100%" 
                height="100%" 
                style="border:0;" 
                allowfullscreen="" 
                loading="lazy" 
                referrerpolicy="no-referrer-when-downgrade">
            </iframe>
        </div>
    </div>
</section>

<%- include('../partials/footer') %>
