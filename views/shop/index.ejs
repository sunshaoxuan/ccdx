<%- include('../partials/header') %>

<section class="h-[70vh] relative overflow-hidden">
    <img src="/assets/hero-jiaozi-bright.png" class="absolute inset-0 w-full h-full object-cover">
    <div class="absolute inset-0 bg-black/10"></div>
    <div class="absolute inset-0 flex flex-col items-center justify-center text-white text-center px-6 fade-in">
        <h1 class="text-5xl md:text-7xl serif mb-6 tracking-[0.2em]"><%= __('home.hero_title') %></h1>
        <p class="text-sm md:text-base tracking-[0.3em] font-light mb-10"><%= __('home.hero_subtitle') %></p>
        <a href="/menu" class="px-10 py-4 border border-white/50 hover:bg-white hover:text-black transition-all duration-500 text-xs tracking-widest"><%= __('home.order_now') %></a>
    </div>
</section>

<!-- 品牌故事章节 -->
<section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-6">
        <div class="flex flex-col md:flex-row gap-16 items-start">
            <div class="w-full md:w-2/5 order-2 md:order-1">
                <h2 class="text-3xl serif tracking-widest mb-8"><%= __('home.craft_title') %></h2>
                <div class="prose prose-lg max-w-none text-gray-500 leading-loose font-light mb-10">
                    <% if (lang === 'zh') { %>
                        <p>CC点心诞生的初衷，是为了找回消失在工业化生产中的“手工温度”。我们相信，每一只饺子都应有它独特的灵魂。</p>
                        <p>我们坚持现包现做，严选高品质食材，从源头确保每一口都安心、地道。支持私人订制，为您还原记忆中的味道。</p>
                    <% } else { %>
                        <p>CC点心が誕生したきっかけは、工業化の中で失われつつある「手仕事の温もり」を取り戻すことでした。一つ一つの餃子には独自の魂が宿ると信じています。</p>
                        <p>私たちは手包みにこだわり、厳選された素材を使用しています。オーダーメイドも可能で、思い出の味を形にします。</p>
                    <% } %>
                </div>
                <a href="/about" class="text-xs tracking-[0.2em] border-b border-[#D4B483] pb-1 hover:text-black transition-colors uppercase"><%= lang === 'zh' ? '阅读完整故事' : '私たちのストーリー' %></a>
            </div>
            <div class="w-full md:w-3/5 order-1 md:order-2">
                <div class="overflow-hidden rounded-sm shadow-sm">
                    <img src="/assets/craftsmanship-jiaozi.png" class="w-full h-auto block">
                </div>
            </div>
        </div>
    </div>
</section>

<!-- 时令推荐 (动态产品) -->
<section class="py-20 max-w-7xl mx-auto px-6">
    <div class="text-center mb-16">
        <h2 class="text-3xl serif tracking-widest mb-4"><%= __('home.seasonal_title') %></h2>
        <div class="w-12 h-[1px] bg-[#D4B483] mx-auto"></div>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
        <% products.forEach(product => { %>
            <div class="group">
                <div class="aspect-[4/5] overflow-hidden mb-6 relative group">
                    <img src="<%= product.imageUrl || '/assets/shrimp-jiaozi.png' %>" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700">
                    <% if (product.mainIngredients && product.mainIngredients.length > 0) { %>
                        <div class="absolute bottom-3 right-3 flex gap-2 z-10">
                            <% product.mainIngredients.forEach(ing => { %>
                                <div class="w-12 h-12 rounded-full bg-white shadow-md border border-gray-100 p-1 overflow-hidden">
                                    <img src="<%= ing.iconUrl %>" class="w-full h-full object-cover rounded-full" title="<%= ing.name[lang] %>">
                                </div>
                            <% }) %>
                        </div>
                    <% } %>
                </div>
                <h3 class="text-lg serif mb-2"><%= product.name[lang] %></h3>
                <div class="text-xs text-gray-400 mb-4 font-light leading-relaxed">
                    <% if (product.ingredients && product.ingredients[lang]) { %>
                        <p class="mb-2"><%= lang === 'zh' ? '配料表' : '原材料' %>: <%= product.ingredients[lang] %></p>
                    <% } %>
                    <p>
                        <% if (product.spec && product.spec[lang]) { %>
                            <span class="mr-2"><%= product.spec[lang] %></span>
                        <% } %>
                        JPY <%= product.price %>
                    </p>
                </div>
                <button onclick="addToCart('<%= product._id %>', '<%= product.name[lang] %>', <%= product.price %>)" class="text-xs tracking-widest border-b border-gray-200 pb-1 hover:border-[#D4B483] transition-colors"><%= __('cart.add_to_cart') %></button>
            </div>
        <% }) %>
    </div>
    <div class="text-center mt-16">
        <a href="/menu" class="text-xs tracking-[0.2em] border border-gray-200 px-12 py-4 hover:bg-black hover:text-white transition-all duration-500 uppercase"><%= __('nav.menu') %></a>
    </div>
</section>

<!-- 专属定制 (新章节) -->
<section class="py-24 bg-[#FDFBF9]">
    <div class="max-w-7xl mx-auto px-6">
        <div class="flex flex-col md:flex-row-reverse gap-20 items-center">
            <div class="w-full md:w-1/2">
                <div class="overflow-hidden rounded-sm shadow-sm">
                    <img src="/assets/bespoke-customization.png" class="w-full h-auto block hover:scale-105 transition-transform duration-1000">
                </div>
            </div>
            <div class="w-full md:w-1/2">
                <h2 class="text-3xl serif tracking-widest mb-8 text-[#2C2C2C]">
                    <%= lang === 'zh' ? '专属定制：还原记忆中的味道' : 'オーダーメイド：思い出の味を再現' %>
                </h2>
                <div class="prose prose-lg text-gray-500 leading-loose font-light mb-10">
                    <% if (lang === 'zh') { %>
                        <p>每个人心中都有一款无可替代的饺子。或许是儿时奶奶亲手调制的馅料，或者是旅途中偶然邂逅的惊喜。在CC点心，我们为您开启“私人订制”服务。</p>
                        <p>您可以自由选择：</p>
                        <ul class="list-none p-0 space-y-2">
                            <li><span class="text-[#D4B483] mr-2">•</span> 馅料比例：肉菜比例由您掌控</li>
                            <li><span class="text-[#D4B483] mr-2">•</span> 特殊忌口：无葱蒜、低盐或特定香料定制</li>
                            <li><span class="text-[#D4B483] mr-2">•</span> 创意搭配：实现您脑海中的独特口味</li>
                        </ul>
                    <% } else { %>
                        <p>誰の心にも、忘れられない特別な餃子の味があります。CC点心では、お客様一人ひとりのための「オーダーメイド」サービスを提供しています。</p>
                        <p>カスタマイズ可能な内容：</p>
                        <ul class="list-none p-0 space-y-2">
                            <li><span class="text-[#D4B483] mr-2">•</span> 餡の黄金比：お好みの肉と野菜のバランス</li>
                            <li><span class="text-[#D4B483] mr-2">•</span> 特別な配慮：ねぎ・にんにく抜き、減塩など</li>
                            <li><span class="text-[#D4B483] mr-2">•</span> 自由な発想：あなただけのオリジナルレシピ</li>
                        </ul>
                    <% } %>
                </div>
                <a href="/info" class="text-xs tracking-[0.2em] border-b border-[#D4B483] pb-1 hover:text-black transition-colors uppercase"><%= lang === 'zh' ? '联系我们开启定制' : 'カスタマイズを相談する' %></a>
            </div>
        </div>
    </div>
</section>

<%- include('../partials/footer') %>

<script>
    function addToCart(id, name, price) {
        let cart = JSON.parse(localStorage.getItem('cart') || '[]');
        const existingItem = cart.find(item => item.productId === id);
        if (existingItem) {
            existingItem.quantity += 1;
        } else {
            cart.push({ productId: id, name: name, price: price, quantity: 1 });
        }
        localStorage.setItem('cart', JSON.stringify(cart));
        alert('<%= lang === "zh" ? "已加入购物车" : "カートに追加されました" %>');
    }
</script>
