<%- include('../partials/header') %>

<section class="h-[70vh] relative overflow-hidden">
    <img src="/assets/hero-jiaozi-bright.png" class="absolute inset-0 w-full h-full object-cover">
    <div class="absolute inset-0 bg-black/10"></div>
    <div class="absolute inset-0 flex flex-col items-center justify-center text-white text-center px-6 fade-in">
        <h1 class="text-5xl md:text-7xl serif mb-6 tracking-[0.2em]"><%= __('home.hero_title') %></h1>
        <p class="text-sm md:text-base tracking-[0.3em] font-light mb-10"><%= __('home.hero_subtitle') %></p>
        <a href="/menu" class="px-10 py-4 border border-white/50 hover:bg-white hover:text-black transition-all duration-500 text-xs tracking-widest"><%= __('home.order_now') %></a>
    </div>
</section>

<section class="py-20 max-w-7xl mx-auto px-6">
    <div class="text-center mb-16">
        <h2 class="text-3xl serif tracking-widest mb-4"><%= __('home.seasonal_title') %></h2>
        <div class="w-12 h-[1px] bg-[#D4B483] mx-auto"></div>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
        <% products.forEach(product => { %>
            <div class="group">
                <div class="aspect-[4/5] overflow-hidden mb-6">
                    <img src="<%= product.imageUrl || '/assets/shrimp-jiaozi.png' %>" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700">
                </div>
                <h3 class="text-lg serif mb-2"><%= product.name[lang] %></h3>
                <p class="text-sm text-gray-400 mb-4">
                    <% if (product.spec && product.spec[lang]) { %>
                        <span class="mr-2"><%= product.spec[lang] %></span>
                    <% } %>
                    JPY <%= product.price %>
                </p>
                <button onclick="addToCart('<%= product._id %>', '<%= product.name[lang] %>', <%= product.price %>)" class="text-xs tracking-widest border-b border-gray-200 pb-1 hover:border-[#D4B483] transition-colors"><%= __('cart.add_to_cart') %></button>
            </div>
        <% }) %>
    </div>
</section>

<%- include('../partials/footer') %>

<script>
    function addToCart(id, name, price) {
        let cart = JSON.parse(localStorage.getItem('cart') || '[]');
        const existingItem = cart.find(item => item.productId === id);
        if (existingItem) {
            existingItem.quantity += 1;
        } else {
            cart.push({ productId: id, name: name, price: price, quantity: 1 });
        }
        localStorage.setItem('cart', JSON.stringify(cart));
        alert('<%= lang === "zh" ? "已加入购物车" : "カートに追加されました" %>');
    }
</script>
