<%- include('../partials/header') %>
<script src="https://yubinbango.github.io/yubinbango/yubinbango.js" charset="UTF-8"></script>

<section class="py-12 md:py-20 max-w-4xl mx-auto px-6">
    <div class="text-center mb-12">
        <h2 class="text-3xl serif tracking-widest mb-4"><%= lang === 'zh' ? '个人中心' : 'マイページ' %></h2>
        <div class="w-12 h-[1px] bg-[#D4B483] mx-auto"></div>
    </div>
    
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        <!-- 基本信息 -->
        <div class="lg:col-span-1 space-y-8">
            <div class="bg-white p-6 border border-gray-50 shadow-sm">
                <h3 class="text-sm tracking-widest uppercase mb-6 pb-2 border-b border-gray-50"><%= lang === 'zh' ? '基本信息' : '基本情報' %></h3>
                
                <% if (typeof req !== 'undefined' && req.query.success) { %>
                    <div class="bg-green-50 text-green-600 p-3 mb-6 text-[10px] text-center">
                        <%= lang === 'zh' ? '信息更新成功！' : 'プロフィールを更新しました！' %>
                    </div>
                <% } %>

                <form action="/profile" method="POST" class="space-y-4">
                    <div>
                        <label class="block text-[10px] tracking-widest text-gray-400 uppercase mb-1"><%= lang === 'zh' ? '用户名' : 'ユーザー名' %></label>
                        <p class="text-sm font-medium"><%= user.username %></p>
                    </div>
                    <div>
                        <label class="block text-[10px] tracking-widest text-gray-400 uppercase mb-1"><%= lang === 'zh' ? '电子邮箱' : 'メールアドレス' %></label>
                        <input type="email" name="email" value="<%= user.email || '' %>" required class="w-full bg-white border border-gray-100 px-3 py-2 text-sm focus:outline-none focus:border-[#D4B483] transition-colors">
                    </div>
                    <div>
                        <label class="block text-[10px] tracking-widest text-gray-400 uppercase mb-1"><%= lang === 'zh' ? '联系电话' : '電話番号' %></label>
                        <input type="text" name="phone" value="<%= user.phone || '' %>" class="w-full bg-white border border-gray-100 px-3 py-2 text-sm focus:outline-none focus:border-[#D4B483] transition-colors">
                    </div>
                    <button type="submit" class="w-full bg-[#2D2D2D] text-white py-3 text-[10px] tracking-[0.2em] hover:bg-[#D4B483] transition-colors duration-500 uppercase">
                        <%= lang === 'zh' ? '保存更改' : '保存する' %>
                    </button>
                </form>
            </div>
            
            <a href="/orders" class="block w-full bg-white border border-gray-100 p-4 text-center text-[10px] tracking-widest hover:text-[#D4B483] transition-colors uppercase">
                <%= lang === 'zh' ? '查看我的订单记录' : '注文履歴を確認する' %>
            </a>
        </div>

        <!-- 地址管理 -->
        <div class="lg:col-span-2 space-y-8">
            <div class="bg-white p-6 border border-gray-50 shadow-sm">
                <div class="flex justify-between items-center mb-6 pb-2 border-b border-gray-50">
                    <h3 class="text-sm tracking-widest uppercase"><%= lang === 'zh' ? '地址管理' : '配送先管理' %></h3>
                    <button onclick="toggleAddressForm()" class="text-[10px] tracking-widest text-[#D4B483] hover:text-black transition-colors uppercase">
                        + <span id="add-btn-text"><%= lang === 'zh' ? '新增地址' : '新規追加' %></span>
                    </button>
                </div>

                <!-- 地址表单 (默认隐藏) -->
                <div id="address-form" class="hidden mb-8 p-4 bg-gray-50 border border-gray-100">
                    <h4 id="form-title" class="text-[10px] tracking-widest text-gray-400 uppercase mb-4"><%= lang === 'zh' ? '新增地址' : '新規追加' %></h4>
                    <form id="adr-form-element" action="/profile/address/add" method="POST" class="space-y-4 h-adr">
                        <span class="p-country-name" style="display:none;">Japan</span>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div>
                                <label class="block text-[10px] tracking-widest text-gray-400 uppercase mb-1"><%= lang === 'zh' ? '收货人姓名' : 'お名前' %></label>
                                <input type="text" name="realName" required class="w-full bg-white border border-gray-100 px-3 py-2 text-sm focus:outline-none focus:border-[#D4B483]">
                            </div>
                            <div>
                                <label class="block text-[10px] tracking-widest text-gray-400 uppercase mb-1"><%= lang === 'zh' ? '联系电话' : '電話番号' %></label>
                                <input type="text" name="phone" required class="w-full bg-white border border-gray-100 px-3 py-2 text-sm focus:outline-none focus:border-[#D4B483]">
                            </div>
                        </div>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div>
                                <label class="block text-[10px] tracking-widest text-gray-400 uppercase mb-1"><%= lang === 'zh' ? '邮政编码 (7位)' : '郵便番号 (7桁)' %></label>
                                <input type="text" name="postalCode" required class="p-postal-code w-full bg-white border border-gray-100 px-3 py-2 text-sm focus:outline-none focus:border-[#D4B483]" placeholder="1234567">
                            </div>
                            <div>
                                <label class="block text-[10px] tracking-widest text-gray-400 uppercase mb-1"><%= lang === 'zh' ? '都道府县' : '都道府県' %></label>
                                <input type="text" name="prefecture" required class="p-region w-full bg-white border border-gray-100 px-3 py-2 text-sm focus:outline-none focus:border-[#D4B483]">
                            </div>
                        </div>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div>
                                <label class="block text-[10px] tracking-widest text-gray-400 uppercase mb-1"><%= lang === 'zh' ? '市区町村' : '市区町村' %></label>
                                <input type="text" name="city" required class="p-locality p-street-address w-full bg-white border border-gray-100 px-3 py-2 text-sm focus:outline-none focus:border-[#D4B483]">
                            </div>
                            <div>
                                <label class="block text-[10px] tracking-widest text-gray-400 uppercase mb-1"><%= lang === 'zh' ? '丁目・番地・号' : '丁目・番地・号' %></label>
                                <input type="text" name="addressLine1" required class="w-full bg-white border border-gray-100 px-3 py-2 text-sm focus:outline-none focus:border-[#D4B483]">
                            </div>
                        </div>
                        <div>
                            <label class="block text-[10px] tracking-widest text-gray-400 uppercase mb-1"><%= lang === 'zh' ? '建筑名・房间号' : '建物名・部屋番号' %></label>
                            <input type="text" name="addressLine2" class="w-full bg-white border border-gray-100 px-3 py-2 text-sm focus:outline-none focus:border-[#D4B483]">
                        </div>
                        <div class="flex items-center space-x-2">
                            <input type="checkbox" name="isDefault" id="isDefault" class="w-4 h-4 text-[#D4B483] border-gray-200 focus:ring-0">
                            <label for="isDefault" class="text-[10px] tracking-widest text-gray-400 uppercase"><%= lang === 'zh' ? '设为默认地址' : 'デフォルトに設定' %></label>
                        </div>
                        <div class="flex space-x-4">
                            <button type="submit" class="flex-1 bg-[#2D2D2D] text-white py-2 text-[10px] tracking-[0.2em] hover:bg-[#D4B483] transition-colors uppercase"><%= lang === 'zh' ? '保存' : '保存' %></button>
                            <button type="button" onclick="toggleAddressForm()" class="flex-1 border border-gray-200 py-2 text-[10px] tracking-[0.2em] hover:bg-gray-100 transition-colors uppercase"><%= lang === 'zh' ? '取消' : 'キャンセル' %></button>
                        </div>
                    </form>
                </div>

                <!-- 地址列表 -->
                <div class="space-y-4">
                    <% if (user.addresses && user.addresses.length > 0) { %>
                        <% user.addresses.forEach(addr => { %>
                            <div class="p-4 border <%= addr.isDefault ? 'border-[#D4B483] bg-[#FCFAF7]' : 'border-gray-50' %> relative group">
                                <div class="flex justify-between items-start mb-2">
                                    <div class="flex items-center space-x-3">
                                        <span class="text-sm font-medium"><%= addr.realName %></span>
                                        <span class="text-xs text-gray-400"><%= addr.phone %></span>
                                        <% if (addr.isDefault) { %>
                                            <span class="text-[8px] bg-[#D4B483] text-white px-1.5 py-0.5 tracking-widest uppercase"><%= lang === 'zh' ? '默认' : 'デフォルト' %></span>
                                        <% } %>
                                    </div>
                                    <div class="flex space-x-3">
                                        <button onclick="editAddress('<%= JSON.stringify(addr) %>')" class="text-[8px] tracking-widest text-gray-400 hover:text-black uppercase"><%= lang === 'zh' ? '编辑' : '編集' %></button>
                                        <% if (!addr.isDefault) { %>
                                            <form action="/profile/address/default/<%= addr._id %>" method="POST" class="inline">
                                                <button type="submit" class="text-[8px] tracking-widest text-gray-400 hover:text-[#D4B483] uppercase"><%= lang === 'zh' ? '设为默认' : 'デフォルトに設定' %></button>
                                            </form>
                                        <% } %>
                                        <form action="/profile/address/delete/<%= addr._id %>" method="POST" class="inline" onsubmit="return confirm('<%= lang === 'zh' ? '确定删除该地址吗？' : 'この住所を削除してもよろしいですか？' %>')">
                                            <button type="submit" class="text-[8px] tracking-widest text-red-300 hover:text-red-500 uppercase"><%= lang === 'zh' ? '删除' : '削除' %></button>
                                        </form>
                                    </div>
                                </div>
                                <p class="text-xs text-gray-500 leading-relaxed">
                                    〒<%= addr.postalCode %> <%= addr.prefecture %><%= addr.city %><%= addr.addressLine1 %><br>
                                    <%= addr.addressLine2 %>
                                </p>
                            </div>
                        <% }) %>
                    <% } else { %>
                        <div class="text-center py-12 border border-dashed border-gray-100">
                            <p class="text-[10px] tracking-widest text-gray-300 uppercase"><%= lang === 'zh' ? '暂无收货地址' : '配送先が登録されていません' %></p>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>
    </div>
</section>

    <script>
        function toggleAddressForm() {
            const form = document.getElementById('address-form');
            const title = document.getElementById('form-title');
            const formElement = document.getElementById('adr-form-element');
            
            // Reset to Add mode
            title.innerText = '<%= lang === "zh" ? "新增地址" : "新規追加" %>';
            formElement.action = '/profile/address/add';
            formElement.reset();
            
            form.classList.toggle('hidden');
        }

        function editAddress(addrJson) {
            const addr = JSON.parse(addrJson);
            const form = document.getElementById('address-form');
            const title = document.getElementById('form-title');
            const formElement = document.getElementById('adr-form-element');
            
            title.innerText = '<%= lang === "zh" ? "编辑地址" : "住所を編集" %>';
            formElement.action = '/profile/address/update/' + addr._id;
            
            // Fill form
            formElement.realName.value = addr.realName;
            formElement.phone.value = addr.phone;
            formElement.postalCode.value = addr.postalCode;
            formElement.prefecture.value = addr.prefecture;
            formElement.city.value = addr.city;
            formElement.addressLine1.value = addr.addressLine1;
            formElement.addressLine2.value = addr.addressLine2 || '';
            formElement.isDefault.checked = addr.isDefault;
            
            form.classList.remove('hidden');
            form.scrollIntoView({ behavior: 'smooth' });
        }
    </script>

<%- include('../partials/footer') %>
