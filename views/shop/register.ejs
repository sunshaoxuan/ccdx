<%- include('../partials/header') %>

<section class="py-20 max-w-lg mx-auto px-6">
    <div class="text-center mb-12">
        <h2 class="text-3xl serif tracking-widest mb-4"><%= __('nav.register') %></h2>
        <div class="w-12 h-[1px] bg-[#D4B483] mx-auto"></div>
    </div>
    
    <% if (typeof error !== 'undefined') { %>
        <div class="bg-red-50 text-red-500 p-4 mb-6 text-sm text-center">
            <%= error %>
        </div>
    <% } %>

    <form action="/register" method="POST" class="space-y-6">
        <div>
            <label class="block text-xs tracking-widest text-gray-400 mb-2"><%= lang === 'zh' ? '用户名' : 'ユーザー名' %></label>
            <input type="text" name="username" required class="w-full bg-white border border-gray-100 px-4 py-3 text-sm focus:outline-none focus:border-[#D4B483] transition-colors">
        </div>
        <div>
            <label class="block text-xs tracking-widest text-gray-400 mb-2"><%= lang === 'zh' ? '邮箱' : 'メールアドレス' %></label>
            <input type="email" name="email" required class="w-full bg-white border border-gray-100 px-4 py-3 text-sm focus:outline-none focus:border-[#D4B483] transition-colors">
        </div>
        <div>
            <label class="block text-xs tracking-widest text-gray-400 mb-2"><%= lang === 'zh' ? '密码' : 'パスワード' %></label>
            <input type="password" name="password" required class="w-full bg-white border border-gray-100 px-4 py-3 text-sm focus:outline-none focus:border-[#D4B483] transition-colors">
        </div>
        <button type="submit" class="w-full bg-[#2D2D2D] text-white py-4 text-xs tracking-[0.2em] hover:bg-[#D4B483] transition-colors duration-500">
            <%= __('nav.register') %>
        </button>
    </form>
</section>

<%- include('../partials/footer') %>
