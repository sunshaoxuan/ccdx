<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CC点心 | CCDX</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@300;400;700&family=Noto+Sans+SC:wght@300;400;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Noto Sans SC', sans-serif; background-color: #FCFAF7; color: #2D2D2D; }
        .serif { font-family: 'Noto Serif SC', serif; }
        .fade-in { animation: fadeIn 1s ease-out; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
    </style>
</head>
<body>
    <nav class="fixed w-full z-50 bg-[#FCFAF7]/90 backdrop-blur-sm border-b border-gray-100">
        <div class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center">
            <a href="/" class="text-2xl tracking-widest serif font-bold">CC点心</a>
            <div class="hidden md:flex space-x-8 text-sm tracking-widest font-light">
                <a href="/" class="hover:text-[#D4B483] transition-colors"><%= __('nav.home') %></a>
                <a href="/about" class="hover:text-[#D4B483] transition-colors"><%= __('nav.about') %></a>
                <a href="/menu" class="hover:text-[#D4B483] transition-colors"><%= __('nav.menu') %></a>
                <a href="/info" class="hover:text-[#D4B483] transition-colors"><%= __('nav.info') %></a>
                <% if (user) { %>
                    <a href="/orders" class="hover:text-[#D4B483] transition-colors"><%= __('nav.orders') %></a>
                    <% if (user.role === 'admin') { %>
                        <a href="/admin" class="hover:text-[#D4B483] transition-colors"><%= __('nav.admin') %></a>
                    <% } %>
                    <a href="/logout" class="hover:text-[#D4B483] transition-colors"><%= __('nav.logout') %></a>
                <% } else { %>
                    <a href="/login" class="hover:text-[#D4B483] transition-colors"><%= __('nav.login') %></a>
                <% } %>
                <a href="/cart" class="hover:text-[#D4B483] transition-colors"><%= __('nav.cart') %></a>
            </div>
            <div class="flex items-center space-x-4">
                <button onclick="setLang('zh')" class="text-xs hover:text-[#D4B483] <%= lang === 'zh' ? 'font-bold' : '' %>">CN</button>
                <span class="text-gray-300 text-xs">|</span>
                <button onclick="setLang('jp')" class="text-xs hover:text-[#D4B483] <%= lang === 'jp' ? 'font-bold' : '' %>">JP</button>
            </div>
        </div>
    </nav>
    <div class="pt-20">
