<%- include('../../partials/header') %>

<section class="py-20 max-w-2xl mx-auto px-6">
    <div class="text-center mb-12">
        <h2 class="text-3xl serif tracking-widest mb-4"><%= __('admin.add_product') %></h2>
        <div class="w-12 h-[1px] bg-[#D4B483] mx-auto"></div>
    </div>

    <form action="/admin/products/add" method="POST" enctype="multipart/form-data" class="space-y-8">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <div>
                <label class="block text-[10px] tracking-widest text-gray-400 uppercase mb-2"><%= __('admin.name_zh') %></label>
                <input type="text" name="name_zh" required class="w-full bg-white border border-gray-100 px-4 py-3 text-sm focus:outline-none focus:border-[#D4B483] transition-colors">
            </div>
            <div>
                <label class="block text-[10px] tracking-widest text-gray-400 uppercase mb-2"><%= __('admin.name_jp') %></label>
                <input type="text" name="name_jp" required class="w-full bg-white border border-gray-100 px-4 py-3 text-sm focus:outline-none focus:border-[#D4B483] transition-colors">
            </div>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <div>
                <label class="block text-[10px] tracking-widest text-gray-400 uppercase mb-2"><%= __('admin.description_zh') || '中文描述' %></label>
                <textarea name="description_zh" class="w-full bg-white border border-gray-100 px-4 py-3 text-sm focus:outline-none focus:border-[#D4B483] transition-colors"></textarea>
            </div>
            <div>
                <label class="block text-[10px] tracking-widest text-gray-400 uppercase mb-2"><%= __('admin.description_jp') || '日文描述' %></label>
                <textarea name="description_jp" class="w-full bg-white border border-gray-100 px-4 py-3 text-sm focus:outline-none focus:border-[#D4B483] transition-colors"></textarea>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <div>
                <label class="block text-[10px] tracking-widest text-gray-400 uppercase mb-2"><%= __('admin.price') %></label>
                <input type="number" name="price" required class="w-full bg-white border border-gray-100 px-4 py-3 text-sm focus:outline-none focus:border-[#D4B483] transition-colors">
            </div>
            <div>
                <label class="block text-[10px] tracking-widest text-gray-400 uppercase mb-2"><%= __('admin.category') %></label>
                <input type="text" name="category" value="jiaozi" class="w-full bg-white border border-gray-100 px-4 py-3 text-sm focus:outline-none focus:border-[#D4B483] transition-colors">
            </div>
        </div>

        <div>
            <label class="block text-[10px] tracking-widest text-gray-400 uppercase mb-2"><%= __('admin.image') %></label>
            <input type="file" name="image" required class="w-full text-xs text-gray-400 file:mr-4 file:py-2 file:px-4 file:border-0 file:text-[10px] file:tracking-widest file:bg-gray-50 file:text-gray-400 hover:file:bg-[#D4B483] hover:file:text-white transition-all">
        </div>

        <button type="submit" class="w-full bg-[#2D2D2D] text-white py-4 text-[10px] tracking-[0.2em] hover:bg-[#D4B483] transition-colors duration-500 uppercase">
            <%= __('admin.save') %>
        </button>
    </form>
</section>

<%- include('../../partials/footer') %>
